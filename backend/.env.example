# Copy this file to .env and fill in your keys
# Never commit .env to git

# Anthropic Claude API (for AI narrative engine + geopolitical prediction)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# GNews API (for live geopolitical headlines)
# Get yours at: https://gnews.io
GNEWS_API_KEY=your_gnews_key_here

# NOAA NWS — public API, no key required
NOAA_USER_AGENT=GCSP-Educational-Simulator/1.0
